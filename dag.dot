digraph DAG {
    node [shape=box fontname="Courier" fontsize=10];
    rankdir=TB;

    N0 [label="#0 Program" style=filled fillcolor=lightblue];
    N1 [label="#1 DeclList"];
    N2 [label="#2 Params"];
    N3 [label="#3 VarDecl\n'n'"];
    N4 [label="#4 Compound"];
    N5 [label="#5 FuncDecl\n'fibonacci'"];
    N6 [label="#6 Params"];
    N7 [label="#7 VarDecl\n'num'"];
    N8 [label="#8 Compound"];
    N9 [label="#9 FuncDecl\n'factorial'"];
    N10 [label="#10 Compound"];
    N11 [label="#11 FuncDecl\n'main'"];

    N0 -> N1 [label="[0]"];
    N1 -> N5 [label="[0]"];
    N1 -> N9 [label="[1]"];
    N1 -> N11 [label="[2]"];
    N2 -> N3 [label="[0]"];
    N5 -> N2 [label="left"];
    N5 -> N4 [label="body"];
    N6 -> N7 [label="[0]"];
    N9 -> N6 [label="left"];
    N9 -> N8 [label="body"];
    N11 -> N10 [label="body"];
}
